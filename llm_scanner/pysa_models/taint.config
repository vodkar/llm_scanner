{
  "comment": "Pysa taint flow rules for llm-scanner",
  "sources": [
    { "name": "UserControlled" },
    { "name": "FileSystem" },
    { "name": "Environment" }
  ],
  "sinks": [
    { "name": "SQL" },
    { "name": "RemoteCodeExecution" },
    { "name": "FileSystem" },
    { "name": "XSS" }
  ],
  "features": [],
  "rules": [
    {
      "name": "Possible SQL Injection",
      "code": 5001,
      "sources": ["UserControlled", "Environment"],
      "sinks": ["SQL"],
      "message_format": "Data from {$sources} may reach SQL sink {$sinks}"
    },
    {
      "name": "Possible Command Injection",
      "code": 5002,
      "sources": ["UserControlled", "Environment"],
      "sinks": ["RemoteCodeExecution"],
      "message_format": "Data from {$sources} may reach command execution sink {$sinks}"
    },
    {
      "name": "Possible Path Traversal",
      "code": 5003,
      "sources": ["UserControlled", "Environment"],
      "sinks": ["FileSystem"],
      "message_format": "Data from {$sources} may reach filesystem sink {$sinks}"
    },
    {
      "name": "Possible Cross-Site Scripting",
      "code": 5004,
      "sources": ["UserControlled"],
      "sinks": ["XSS"],
      "message_format": "Data from {$sources} may reach XSS sink {$sinks}"
    }
  ]
}
